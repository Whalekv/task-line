<Window x:Class="TaskLine.Views.AddTaskDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新建任务"
        Width="380" Height="252"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="White">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="0" />
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 对话框标题栏 -->
        <Grid Grid.Row="0" Background="White">
            <TextBlock Text="新建任务"
                       Foreground="#424242"
                       FontSize="13"
                       FontWeight="Medium"
                       VerticalAlignment="Center"
                       Margin="14,0" />
            <Button Style="{StaticResource CloseButton}"
                    Height="36"
                    Content="&#xE8BB;"
                    HorizontalAlignment="Right"
                    IsCancel="True"
                    Click="OnCancelClick" />
        </Grid>

        <!-- 内容区 -->
        <StackPanel Grid.Row="1" Margin="20,16,20,20">

            <TextBlock Text="任务名称"
                       FontSize="12"
                       Foreground="#616161"
                       Margin="0,0,0,4" />
            <TextBox x:Name="TitleTextBox"
                     Padding="8,6"
                     FontSize="14"
                     BorderBrush="#BDBDBD"
                     BorderThickness="1"
                     VerticalContentAlignment="Center">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <TextBlock Text="日期"
                       FontSize="12"
                       Foreground="#616161"
                       Margin="0,14,0,4" />
            <DatePicker x:Name="DatePickerControl"
                        FontSize="14"
                        Height="32" />

            <!-- 操作按钮 -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">
                <Button Content="取消"
                        Style="{StaticResource OutlineButton}"
                        Width="72" Height="32"
                        FontSize="13"
                        Margin="0,0,8,0"
                        IsCancel="True"
                        Click="OnCancelClick" />
                <Button x:Name="ConfirmButton"
                        Content="确认"
                        Style="{StaticResource PrimaryButton}"
                        Width="72" Height="32"
                        FontSize="13"
                        IsDefault="True"
                        IsEnabled="False"
                        Click="OnConfirmClick" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
